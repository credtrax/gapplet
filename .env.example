# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this file is not.

# Supabase — from Settings → API in the project dashboard.
# The publishable (anon) key is designed to be public-safe; it's bundled into the client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
